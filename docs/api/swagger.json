{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "mc-web-console BFF API server (Echo). Auth, disk lookup, admin BFF, and multi-cloud proxy via /api/{subsystemName}/{operationId}.",
        "title": "mc-web-console API",
        "contact": {},
        "version": "1.0.0"
    },
    "host": "localhost:3100",
    "basePath": "/",
    "paths": {
        "/api/admin/setup-yaml-check": {
            "get": {
                "description": "Probe external raw YAML URLs (menu or api catalog) for admin setup status",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "admin"
                ],
                "summary": "Setup YAML reachability check",
                "parameters": [
                    {
                        "enum": [
                            "menu",
                            "api"
                        ],
                        "type": "string",
                        "description": "Target YAML",
                        "name": "which",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "allOf": [
                                {
                                    "$ref": "#/definitions/mc_web_console_api_internal_model.CommonResponse"
                                },
                                {
                                    "type": "object",
                                    "properties": {
                                        "responseData": {
                                            "$ref": "#/definitions/internal_handler.SetupYamlCheckResult"
                                        }
                                    }
                                }
                            ]
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/mc_web_console_api_internal_model.CommonResponse"
                        }
                    }
                }
            }
        },
        "/api/auth/login": {
